### PS Project 2 - Gateway Endpoints
### Base URL: http://localhost:8083
### Compatible with: JetBrains HTTP Client, VS Code REST Client

@base = http://localhost:8083
@apiKey = RAF-ADMIN-1744320000-abc123def456-admin


# ─────────────────────────────────────────────
# AUTH SERVICE
# ─────────────────────────────────────────────

### Register User
POST {{base}}/api/auth/register
Content-Type: application/json

{
  "username": "testuser",
  "roles": ["USER"]
}

### Validate API Key
GET {{base}}/api/auth/validate
X-API-KEY: test-key

### Find User by Username
GET {{base}}/api/auth/find/testuser


# ─────────────────────────────────────────────
# SMESTAJ - UNITS
# ─────────────────────────────────────────────

### Create Unit
POST {{base}}/api/units/add
Content-Type: application/json
X-API-KEY: {{apiKey}}

{
  "name": "Apartman Centar",
  "unit_type": "APARTMAN",
  "basePricePerNight": 89.99,
  "streetAddress": "Knez Mihailova 25",
  "city": "Beograd",
  "zip_code": "11000"
}

> {%
    client.test("Create Unit - 201 i kreirana jedinica", function() {
        client.assert(response.status === 201, "Ocekivan status 201, dobijen " + response.status);
        client.assert(response.body.id !== undefined, "Odgovor mora sadrzati id kreirane jedinice");
        client.assert(response.body.name === "Apartman Centar", "Ime kreirane jedinice se ne poklapa");
    });
    client.global.set("createdUnitId", response.body.id);
%}

### Get All Units
GET {{base}}/api/units/all
X-API-KEY: {{apiKey}}

> {%
    client.test("Get All Units - 200 i lista jedinica", function() {
        client.assert(response.status === 200, "Ocekivan status 200, dobijen " + response.status);
        client.assert(Array.isArray(response.body), "Odgovor mora biti niz jedinica");
    });
%}

### Get Unit by ID
GET {{base}}/api/units/1
X-API-KEY: {{apiKey}}

> {%
    client.test("Get Unit by ID - vraca jedinicu sa id=1", function() {
        client.assert(response.status === 200, "Ocekivan status 200, dobijen " + response.status);
        client.assert(response.body.id === 1, "Vracena jedinica nema ocekivani id=1");
    });
%}

### Check Unit Exists
GET {{base}}/api/units/1/exists
X-API-KEY: {{apiKey}}

> {%
    client.test("Check Unit Exists - true za postojecu jedinicu", function() {
        client.assert(response.status === 200, "Ocekivan status 200, dobijen " + response.status);
        client.assert(response.body === true, "Jedinica sa id=1 bi trebalo da postoji");
    });
%}

