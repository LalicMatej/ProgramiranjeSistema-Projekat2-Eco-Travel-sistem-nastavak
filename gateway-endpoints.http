### Create Adventure
POST {{base}}/api/avanture/adventures/add
Content-Type: application/json

{
  "title": "Planinski uspon",
  "description": "Uzbudljiva avantura na planini",
  "difficulty_level": "MEDIUM",
  "base_price": 150.0,
  "adventure_categoriesRequest": {
    "name": "Planinarenje",
    "description": "Velik uspon"
  },
  "guide_id": 1,
  "guideLevelRequired": 2
}

### Get All Adventures
GET {{base}}/api/avanture/adventures/all

### Get Adventure by ID
GET {{base}}/api/avanture/adventures/1

### Update Adventure
PUT {{base}}/api/avanture/adventures/update/1
Content-Type: application/json

{
  "title": "Planinski uspon - Azurirano",
  "description": "Azuriran opis avanture",
  "difficulty_level": "HARD",
  "base_price": 200.0,
  "adventure_categoriesRequest": {
    "name": "Planinarenje",
    "description": "Velik uspon"
  },
  "guide_id": 1,
  "guideLevelRequired": 3
}

### Delete Adventure
DELETE {{base}}/api/avanture/adventures/delete/1

