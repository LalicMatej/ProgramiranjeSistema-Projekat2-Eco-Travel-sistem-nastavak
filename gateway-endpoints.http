{
  "name": "Planinski vodic - nivo 3",
  "issuing_body": "Planinarsko drustvo Srbije",
  "expiry_date": "2028-01-01",
  "guidesRequest": {
    "first_name": "Nikola",
    "last_name": "Nikolic",
    "bio": "Iskusni planinski vodic sa 10 godina iskustva",
    "rating": 4.5
  },
  "certificationLevel": 3
}

### Get All Certifications
GET {{base}}/api/vodici/certifications/all

### Get Certification by ID
GET {{base}}/api/vodici/certifications/1

### Update Certification
PUT {{base}}/api/vodici/certifications/update/1
